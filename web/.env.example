# ─────────────────────────────────────────────────────────────
# Smart capture (optional): distil pasted text into memories.
# The rest of the app (storage + local RAG retrieval) needs no key.
# Set ONE provider's key. If both are set, EXTRACTION_PROVIDER decides.
# ─────────────────────────────────────────────────────────────

# OpenAI (has generous free-tier credits on new accounts)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Which provider to use when more than one key is set: "openai" | "anthropic"
EXTRACTION_PROVIDER=openai

# ─────────────────────────────────────────────────────────────
# Persistence (production): Upstash Redis. When these two are set, memories
# are stored in Redis instead of the local JSON file — required on serverless
# hosts (Vercel) where the filesystem is read-only. Leave blank locally.
# Get them free at https://console.upstash.com (Redis database -> REST).
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Security (optional): when set, the API requires this token.
# The dashboard is auto-allowed (same-origin); the browser extension
# must send the same token (set it in the extension's toolbar popup).
# Recommended in production so your public API isn't wide open.
# Leave blank for a zero-config local run.
# ─────────────────────────────────────────────────────────────
PB_TOKEN=
